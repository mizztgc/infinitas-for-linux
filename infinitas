#!/usr/bin/env bash

###################
# WARNING: THIS IS ONLY A LAUNCH SCRIPT FOR BEATMANIA IIDX INFINITAS. THERE ARE NO INSTALLATION
# FUNCTIONS INCLUDED WITH THIS SCRIPT! RUN THE INSTALLATION FUNCTION FROM THE SCRIPT IN THE MAIN
# BRANCH AND REPLACE IT WITH THIS SCRIPT ONCE IT COMPLETES
###################

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
DEFAULT_PREFIX_LOCATION="$HOME/.local/share/konaste"

# Game information
GAME_TITLE='beatmania IIDX INFINITAS'
DIR_TITLE="${GAME_TITLE}"
SIMPLE_NAME="infinitas"
INSTALLER_LINK="https://d1rc4pwxnc0pe0.cloudfront.net/v2/installer/infinitas_installer_2022060800.msi"
LAUNCH_PAGE="https://p.eagate.573.jp/game/infinitas/2/api/login/login.html"
LAUNCHER_NAME='bm2dx_launcher'
URI='bm2dxinf'

log() {
	[[ -z "$1" ]] && return 1
	[[ -z "$2" ]] && return 1
	[[ -n "$container" && "$container" == 'flatpak' ]] && {
		shift
		echo -e "${@}"
		return 0
	}
	declare -Ia logOutput=()
	[[ $TERM != 'dumb' ]] && case "$1" in
		warn)
			logOutput+=( "\033[1;93m->\033[39m WARNING:\033[0m" )
			;;
		err)
			logOutput+=( "\033[1;91m->\033[39m ERROR:\033[0m" )
			;;
		ok)
			logOutput+=( "\033[1;92m->\033[39m SUCCESS:\033[0m" )
			;;
		info|-|--)
			logOutput+=( "\033[1;96m->\033[39m INFO:\033[0m" )
			;;
	esac
	shift

	logOutput+=( "${@}\033[0m" )
	echo -e "${logOutput[@]}"
	return 0
}

[[ -n $container && $container == 'flatpak' ]] && {
	log err "Do NOT run this script directly through a Flatpak container."
	exit 126
}

generate_launch_script() {
cat > "/tmp/${SIMPLE_NAME}.sh" <<EOF
# Why are you even reading this?
# Can you like, go away?

export WINEPREFIX=${_PREFIX}
export WINEDEBUG='fixme-all'
export DXVK_LOG_LOVEL='error'

"${WINESERVER[@]}" -p2
"${WINE[@]}" start ${WINE_LAUNCH_ARGS[@]} '${LAUNCHER_EXECUTABLE}' "$LOGIN_TOKEN" 2>/dev/null
"${WINESERVER[@]}" -w
exit \$?
EOF
	chmod a+x "/tmp/${SIMPLE_NAME}.sh"
	echo -n "/tmp/${SIMPLE_NAME}.sh" # This won't be outputted to the terminal.
}

locate_files() {
	[[ -n "$LAUNCHER_EXECUTABLE" ]] && return 0

	[[ ! -e "${_PREFIX}" ]] && return 1
	[[ ! -d "${_PREFIX}" ]] && return 2
	[[ ! -f "${_PREFIX[@]}/system.reg" ]] && return 3
	[[ ! -d "${_PREFIX[@]}/dosdevices/c:/Games/${DIR_TITLE}" ]] && return 4
	[[ ! -d "${_PREFIX[@]}/dosdevices/c:/Games/${DIR_TITLE}/Resource" ]] && return 5
	[[ ! -f "${_PREFIX[@]}/dosdevices/c:/Games/${DIR_TITLE}/launcher/modules/${LAUNCHER_NAME}.exe" ]] && return 6

# 	if [[ $_useFlatpak ]]; then
# 		declare -gr LAUNCHER_EXECUTABLE="$($FLATPAK run "${FLATPAK_EXTRA_ARGS[@]}" --command=/bin/bash org.winehq.Wine -c "/app/bin/winepath -w "${_PREFIX[@]}/dosdevices/c:/Games/${DIR_TITLE}/launcher/modules/${LAUNCHER_NAME}.exe" ")"
# 	else
# 		declare -gr LAUNCHER_EXECUTABLE="$(${WINEPATH[@]} -w "${_PREFIX[@]}/dosdevices/c:/Games/${DIR_TITLE}/launcher/modules/${LAUNCHER_NAME}.exe")"
# 	fi
	declare -gr LAUNCHER_EXECUTABLE="C:\\\\Games\\\\${DIR_TITLE}\\\\launcher\\\\modules\\\\${LAUNCHER_NAME}.exe"
	return 0
}

set_vars() {
	# Declare the important things
	declare -gr FLATPAK="$(command -v flatpak)"
	declare -gr PW_LOOPBACK="$(command -v pw-loopback)"
	declare -gr KDIALOG="$(command -v kdialog)"
	declare -gr GAMEMODE="$(command -v gamemoderun)"
	declare -gr GAMESCOPE="$(command -v gamescope)"

	[[ -z $KDIALOG ]] && log - "Unable to locate binary for \033[1mkdialog\033[22m. Please install it from your distribution's package manager." && exit 5
	[[ -z $PW_LOOPBACK ]] && {
		log err "Unable to locate binary for \033[1mpw-loopback\033[22m. Please make sure \033[1mPipeWire\033[22m is installed from your distribution's package manager."
		$KDIALOG --title "${GAME_TITLE} - ERROR" \
			--error "Unable to locate binary for <code>pw-loopback</code>.<br>Please make sure <strong>PipeWire</strong> is installed from your distribution's package manager."
		exit 6
	}

	# Declare arrays
	declare -ag FLATPAK_EXTRA_ARGS=( --filesystem='/tmp' ) # Arguments if running with Flatpak
	declare -ag PRELAUNCH_ARGS=( ) # Commands to run before launching Wine
	declare -ag WINE_LAUNCH_ARGS=( /high /wait ) # Launch arguments for Wine (it makes it easier to allow for use of Wine's virtual desktop)

	# Remove the launch script if it's still lingering
	[[ -f "/tmp/${SIMPLE_NAME}.sh" ]] && rm "/tmp/${SIMPLE_NAME}.sh"

	flatpak_check() {
		# Check to see if Flatpak is not installed
		[[ -z $FLATPAK ]] && return 1

		# Search for Flatpak Wine (org.winehq.Wine)
		if [[ $($FLATPAK list --user --app --columns=application | grep -w 'org.winehq.Wine') ]]; then
			FLATPAK_EXTRA_ARGS+=( '--user' )
		elif [[ -n $($FLATPAK list --system --app --columns=application | grep -w 'org.winehq.Wine') ]]; then
			FLATPAK_EXTRA_ARGS+=( '--system' )
		else
			unset FLATPAK_EXTRA_ARGS
			return 2
		fi

		return 0
	}

	wineversion_check() {
		if [[ $_useFlatpak ]]; then
			IFS='-' read -r -d '(' -a wine_ver < <($FLATPAK run org.winehq.Wine --version)
		else
			IFS='-' read -r -d '(' -a wine_ver < <("${_WINEBUILD}/bin/wine" --version)
		fi

		[[ ${wine_ver[0]} != 'wine' ]] && return 2
		for w in ${wine_ver[@]}; do
			if [[ $(grep -w '.' <<< "$w") ]]; then
				v=$(cut -d'.' -f1 <<< "$w")
				if [[ ${v[0]} -lt 9 ]]; then
					return 1
				fi
			fi
		done

		return 0
	}

	wine_check() {
		# Check if the Wine variables are already set
		[[ -n "${WINE}" && -n "${WINESERVER}" ]] && return 0

		# Check if the Winebuild variable is not set
		if [[ -z "${_WINEBUILD}" ]]; then
			if [[ $_useFlatpak ]]; then
				declare -gr WINE="/app/bin/wine"
				declare -gr WINESERVER="/app/bin/wineserver"
				declare -gr WINEPATH="/app/bin/winepath"
				return 0
			else
				# Check for a build of Wine in $PATH
				if [[ ! $(command -v wine) ]]; then
					return 1
				fi

				# Declare _WINEBUILD to the directory the Wine binary is located in
				declare -gr _WINEBUILD="$(cd -- $(dirname -- "$(command -v wine)")/.. && pwd)"
			fi
		fi

		# Basic checks
		[[ ! -e "${_WINEBUILD}" ]] && return 2
		[[ ! -d "${_WINEBUILD}" ]] && return 3
		[[ ! -d "${_WINEBUILD}/bin" ]] && return 4
		[[ ! -f "${_WINEBUILD}/bin/wine" ]] && return 5
		[[ ! -x "${_WINEBUILD}/bin/wine" ]] && return 6

		# Oh, and make sure this is actually a 64-bit Wine binary
		[[ ! -f "${_WINEBUILD}/bin/wine64" && ! -f "${_WINEBUILD}/bin/wine64-preloader" ]] && return 7
		declare -gr WINE="${_WINEBUILD}/bin/wine"
		declare -gr WINESERVER="${_WINEBUILD}/bin/wineserver"
		declare -gr WINEPATH="${_WINEBUILD}/bin/winepath"
		return 0
	}

	# Look in the script directory and the default config location for the config file
	if [[ -f "${SCRIPT_DIR}/${SIMPLE_NAME}.conf" || -f "$HOME/.config/konaste/${SIMPLE_NAME}.conf" ]]; then
		if [[ -f "${SCRIPT_DIR}/${SIMPLE_NAME}.conf" ]]; then
			log - "Found configuration file for ${GAME_TITLE} in script directory"
			source "${SCRIPT_DIR}/${SIMPLE_NAME}.conf"
		else
			log - "Found configuration file for ${GAME_TITLE} in ~/.config/konaste"
			source "$HOME/.config/konaste/${SIMPLE_NAME}.conf"
		fi

		# Flatpak check
		if [[ $use_flatpak && $use_flatpak == 'true' ]]; then
			flatpak_check; case $? in
				0)	# Found Flatpak build of Wine
					log - "Using Flatpak"
					declare -gr _useFlatpak=true
					;;
				1)	# Couldn't find Flatpak on your system
					log err "Unable to locate binary for \033[1mflatpak\033[22m."
					$KDIALOG --title "${GAME_TITLE} - FLATPAK ERROR" \
						--warningyesno "You have enabled support for <strong>Flatpak</strong> in your configuration file for ${GAME_TITLE}, but <code>flatpak</code> was not found on your system.<br><br><strong>Attempt to use a native build of Wine?</strong>"
					if [[ $? -eq 1 ]]; then
						$KDIALOG --title "${GAME_TITLE} - ERROR" \
							--error "${GAME_TITLE} cannot start with Flatpak support without <code>flatpak</code> installed on your system.<br>Please install <code>flatpak</code> from your distribution's package manager, or set <code>use_flatpak</code> to <code>false</code> in your configuration file."
						exit 7
					fi
					;;
				2)	# Found Flatpak, but not the Flatpak build of Wine
					log err "Unable to find Wine (Flatpak)"
					$KDIALOG --title "${GAME_TITLE} - FLATPAK ERROR"
						--warningyesno "You have enabled support for <strong>Flatpak</strong> in your configuration file for ${GAME_TITLE}, but Wine (Flatpak) is not installed.<br><br><strong>Attempt to use a native build of Wine?</strong>"
					if [[ $? -eq 1 ]]; then
						$KDIALOG --title "${GAME_TITLE} --error" \
							--error "${GAME_TITLE} cannot start without the Flatpak build of Wine installed on your system. In a terminal emulator, please run the following command:<br><br>  <code>flatpak install org.winehq.Wine//stable-23.08</code>"
						exit 8
					fi
					;;
			esac
		fi

		if [[ $XDG_SESSION_TYPE == 'wayland' ]]; then
			log warn "Wayland detected; expect issues"
			$KDIALOG --title "Wayland Warning" \
				--sorry "You appear to be playing in a Wayland session. Because Wayland only exposes your current refresh rate to applications, this usually ends up with ${GAME_TITLE} failing to find a supported display mode. Before you start playing, ensure that your refresh rate is set to 60Hz (or 120Hz if supported) if it isn't already.<br><br>Alternatively, you can try playing in an Xorg session, which does not suffer from this problem." \
				--dontagain "$HOME/.config/konaste/ignore.conf":waylandWarning
		fi

		if [[ -n $prefix ]]; then
			log - "Setting prefix location to \033[1m${prefix}\033[22m"
			declare -gr _PREFIX="${prefix}"
		else
			log warn "No variable for \033[1mprefix\033[0m was specified. Defaulting to ${DEFAULT_PREFIX_LOCATION}..."
			declare -gr _PREFIX="${DEFAULT_PREFIX_LOCATION}"
		fi

		# Allow the Flatpak container to have access to the prefix directory
		[[ $_useFlatpak ]] && FLATPAK_EXTRA_ARGS+=( --filesystem="${_PREFIX}" )

		# Custom wine directory check
		if [[ -n $custom_wine ]]; then
			log - "Setting Wine build directory to \033[1m${custom_wine}\033[22m"
			declare -gr _WINEBUILD="${custom_wine}"

			# Allow Flatpak to only be able to read from the custom Wine build directory
			[[ $_useFlatpak ]] && FLATPAK_EXTRA_ARGS+=( --filesystem="${_WINEBUILD}:ro" )
		fi

		# Set PulseAudio latency
		if [[ -n $pa_latency ]]; then
			if [[ $pa_latency -lt 35 ]]; then
				log warn "PulseAudio latency is set to below 35ms. Expect distored audio!"
			elif [[ $pa_latency -gt 80 ]]; then
				log warn "PulseAudio latency is set to above 80ms. Expect higher audio latency!"
			fi

			export PULSE_LATENCY_MSEC=$pa_latency
		fi

		# Use gamemoded
		if [[ -n $use_gamemode && $use_gamemode == 'true' ]]; then
			if [[ -n $GAMEMODE ]]; then
				PRELAUNCH_ARGS+=( "$GAMEMODE" )
			else
				log warn "use_gamemode is set to true, but a binary for gamemoderun couldn't be found on your system."
			fi
		fi

		# Use Gamescope (NOT RECOMMENDED)
		if [[ -n $use_gamescope && $use_gamescope == 'true' ]]; then
			if [[ -n $GAMESCOPE ]]; then
				PRELAUNCH_ARGS+=( "$GAMESCOPE" -w 1920 -h 1080 -r 120 --framerate-limit 120 -f -- )
				WINE_LAUNCH_ARGS+=( explorer '/desktop=infinitas,1920x1080' )
				$KDIALOG --title "${GAME_TITLE} - GAMESCOPE WARNING" \
					--sorry "You have enabled support for Gamescope. Please keep in mind that Gamescope does <strong><em>NOT</em></strong> play well with Wine, and may require you to manually kill once you are done playing.<br>Wine's Virtual Desktop feature will also be enabled."
			else
				log warn "use_gamescope is set to true, but a binary for gamescope couldn't be found on your system."
			fi
		fi

		# Use Wine Virtual Desktop
		if [[ -n $use_winevd && $use_winevd == 'true' ]]; then
			if [[ -n $custom_wine && $use_gamescope != 'true' ]]; then
				$KDIALOG --title "${GAME_TITLE} - WARNING" \
					--sorry "You appear to be using a custom build of Wine and have enabled the Wine virtual desktop in your configuration file. Some custom builds may not allow this script to force the resolution and refresh rate of the virtual desktop, and will have to rely on your current display settings.<br><br>If you have issues with this, consider using a vanilla build of Wine, or enable gamescope." \
					--dontagain "$HOME/.config/konaste/ignore.conf":customWineVD
			fi
			WINE_LAUNCH_ARGS+=( explorer '/desktop=infinitas,1920x1080' )
		fi
	else
		# Use defaults
		log warn "Unable to locate configuration file for ${GAME_TITLE}. Using defaults..."
		declare -gr _PREFIX="${DEFAULT_PREFIX_LOCATION}"

		if [[ -n $GAMEMODE ]]; then
			PRELAUNCH_ARGS+=( "$GAMEMODE" )
		fi

		if [[ $XDG_SESSION_TYPE == 'wayland' ]]; then
			log warn "Wayland detected; enabling virtual desktop"
			WINE_LAUNCH_ARGS+=( explorer '/desktop=infinitas,1920x1080' )
		fi

		export PULSE_LATENCY_MSEC=40
	fi

	wine_check; case $? in
		0)	# Valid Wine build detected
			[[ ! $_useFlatpak && $custom_wine ]] && {
				log - "Setting WINE to ${WINE[@]}"
				log - "Setting WINEPATH to ${WINEPATH[@]}"
				log - "Setting WINESERVER to ${WINESERVER[@]}"
			}

			wineversion_check; case $? in
				1)
					log err "Out of date Wine build detected"
					$KDIALOG --title "${GAME_TITLE} - ERROR" \
						--error "The specified Wine build directory is out of date.<br>This script requires a build of Wine <strong>9.0</strong> or later"
					exit 22
					;;
				2)
					log err "Invalid Wine binary detected"
					$KDIALOG --title "${GAME_TITLE} - ERROR" \
						--error "The specified Wine build directory does not contain a valid wine binary."
					exit 21
					;;
			esac
			;;
		1)	# Wine is not installed
			log err "Unable to find binary for wine"
			$KDIALOG --title "${GAME_TITLE} - ERROR" \
				--error "<strong>Wine</strong> was not found on your system.<br>Please install <code>wine</code> from your distribution's package manager or Flatpak"
			exit 15
			;;
		2)	# Unable to locate Wine build directory
			log err "Unable to find Wine build directory"
			$KDIALOG --title "${GAME_TITLE} - ERROR" \
				--error "Unable to locate the specified Wine build at <code>${_WINEBUILD}</code>"
			exit 16
			;;
		3)	# Wine build location is not a directory
			log err "Specified Wine build is not a directory"
			$KDIALOG --title "${GAME_TITLE} - ERROR" \
				--error "The specified Wine build is not a directory."
			exit 17
			;;
		4)	# Wine build location does not have a 'bin' directory
			log err "Unable to locate bin directory in ${_WINEBUILD}"
			$KDIALOG --title "${GAME_TITLE} - ERROR" \
				--error "The specified Wine build directory does not contain a directory named '/bin'"
			exit 18
			;;
		5)	# No 'wine' binary
			log err "Unable to locate binary for wine in ${_WINEBUILD}"
			$KDIALOG --title "${GAME_TITLE} - ERROR" \
				--error "The specified Wine build directory does not contain a wine binary."
			exit 19
			;;
		6)	# Wine binary is not executable
			log err "wine binary in ${_WINEBUILD} is not executable"
			$KDIALOG --title "${GAME_TITLE} - ERROR" \
				--error "The <code>wine</code> binary in <code>${_PREFIX}</code> is not executable. In a terminal, run the following command:<br>  <code>chmod a+x ${_WINEBUILD}/bin/wine*</code>"
			exit 20
			;;
		7)	# Wine build is not 64-bit.
			log err "Wine build is not a 64-bit build"
			$KDIALOG --title "${GAME_TITLE} - ERROR" \
				--error "The specified Wine build directory does not contain a wine64 binary.<br>This script requires a 64-bit build of Wine."
			exit 32 # why not lol
			;;
	esac
}

# Check for a login token
if [[ $# -eq 1 && "$1" =~ "${URI}" ]]; then
	[[ $TERM != 'dumb' ]] && log warn "Avoid passing login tokens directly to this script."
	declare -gr LOGIN_TOKEN="$1"
fi

set_vars
locate_files; case $? in
	0)	# Found game
		log - "Found ${GAME_TITLE} launcher"

		# Open the launch page if no login token is provided.
		if [[ -z "$LOGIN_TOKEN" ]]; then
			log err "No login token was specified. Opening launch page..."
			exec xdg-open "$LAUNCH_PAGE"
		fi

		# start PipeWire loopback device
		log - "Starting PipeWire loopback device..."
		$PW_LOOPBACK -m '[ FL FR ]' --capture-props='media.class=Audio/Sink node.name=konaste node.description=Konaste audio.rate=44100' &

		# Set exports
		export WINEPREFIX="${_PREFIX}"
		export WINEDLLOVERRIDES="${WINEDLLOVERRIDES};mscoree;mshtml=d"
		export WINEDEBUG='fixme-all'
		export PULSE_SINK='konaste'

		# Now to launch the game!
		log - "Generating launch script for ${GAME_TITLE}..."
		tempScript="$(generate_launch_script)"
		log - "Executing $tempScript..."
		if [[ $_useFlatpak ]]; then
			FLATPAK_EXTRA_ARGS+=( --env=WINEPREFIX="${_PREFIX}" --env=WINEDLLOVERRIDES='mscoree;mshtml=d' --env=WINEDEBUG='fixme-all' )
			"${PRELAUNCH_ARGS[@]}" $FLATPAK run "${FLATPAK_EXTRA_ARGS[@]}" --command=/bin/bash org.winehq.Wine -c "$tempScript" 2>/dev/null
		else
			"${PRELAUNCH_ARGS[@]}" bash -c "$tempScript" 2>/dev/null
		fi

		rm "$tempScript"
		log - "${GAME_TITLE} ended. Terminating loopback device..."
		kill -15 $(jobs -p)

		# IIDX EMPRESS has a very goated credits song.
		# don't @ me.
		echo -e "\n\033[1;95mThank you for playing...\033[0m\n"
		exit $?
		;;
	1)
		log err "Unable to find prefix at ${_PREFIX}"
		$KDIALOG --title "${GAME_TITLE} - ERROR" \
			--error "Unable to locate the Wineprefix at <code>${_PREFIX}</code>"
		exit 40
		;;
	2)
		log err "Specified prefix is not a directory"
		$KDIALOG --title "${GAME_TITLE} - ERROR" \
			--error "The specified Wineprefix at <code>${_PREFIX}</code> is not a directory"
		exit 41
		;;
	3)
		log err "Specified prefix is not a valid prefix"
		$KDIALOG --title "${GAME_TITLE} - ERROR" \
			--error "The specified Wineprefix at <code>${_PREFIX}</code> is missing <code>system.reg</code>, and/or may be corrupted."
		exit 42
		;;
	4)
		log err "Unable to locate ${GAME_TITLE} install directory"
		$KDIALOG --title "${GAME_TITLE} - ERROR" \
			--error "Unable to locate the install directory for ${GAME_TITLE}"
		exit 43
		;;
	5)
		log err "Unable to locate ${GAME_TITLE}'s resource directory"
		$KDIALOG --title "${GAME_TITLE} - ERROR" \
			--error "Unable to locate the resource directory for ${GAME_TITLE}"
		exit 44
		;;
	6)
		log err "Unable to locate ${GAME_TITLE}'s launcher"
		$KDIALOG --title "${GAME_TITLE} - ERROR" \
			--error "Unable to locate the launcher for ${GAME_TITLE}"
		exit 45
		;;
esac
