generate_launch_script() {
cat > "/tmp/${SIMPLE_NAME}.sh" <<EOF
# Why are you even reading this?
# Can you like, go away?

export WINEPREFIX=${_PREFIX}
export WINEDEBUG='fixme-all'
export DXVK_LOG_LEVEL='error'

"${WINESERVER[@]}" -p2
"${WINE[@]}" start ${WINE_LAUNCH_ARGS[@]} '${LAUNCHER_EXECUTABLE}' "$LOGIN_TOKEN" 2>/dev/null
"${WINESERVER[@]}" -w
exit \$?
EOF
	chmod a+x "/tmp/${SIMPLE_NAME}.sh"
	echo -n "/tmp/${SIMPLE_NAME}.sh" # This won't be outputted to the terminal.
}

locate_files() {
	[[ -n "$LAUNCHER_EXECUTABLE" ]] && return 0

	[[ ! -e "${_PREFIX}" ]] && return 1
	[[ ! -d "${_PREFIX}" ]] && return 2
	[[ ! -f "${_PREFIX[@]}/system.reg" ]] && return 3
	[[ ! -d "${_PREFIX[@]}/dosdevices/c:/Games/${DIR_TITLE}" ]] && return 4
	[[ ! -d "${_PREFIX[@]}/dosdevices/c:/Games/${DIR_TITLE}/Resource" ]] && return 5
	[[ ! -f "${_PREFIX[@]}/dosdevices/c:/Games/${DIR_TITLE}/launcher/modules/${LAUNCHER_NAME}.exe" ]] && return 6

# 	if [[ $_useFlatpak ]]; then
# 		declare -gr LAUNCHER_EXECUTABLE="$($FLATPAK run "${FLATPAK_EXTRA_ARGS[@]}" --command=/bin/bash org.winehq.Wine -c "/app/bin/winepath -w "${_PREFIX[@]}/dosdevices/c:/Games/${DIR_TITLE}/launcher/modules/${LAUNCHER_NAME}.exe" ")"
# 	else
# 		declare -gr LAUNCHER_EXECUTABLE="$(${WINEPATH[@]} -w "${_PREFIX[@]}/dosdevices/c:/Games/${DIR_TITLE}/launcher/modules/${LAUNCHER_NAME}.exe")"
# 	fi
	declare -gr LAUNCHER_EXECUTABLE="C:\\\\Games\\\\${DIR_TITLE}\\\\launcher\\\\modules\\\\${LAUNCHER_NAME}.exe"
